# Copy this file to ".env" and edit the values for your deployment.
# .env is gitignored — do not commit your real values.

# ---- Site ----
# Display name shown in the topbar.
SCRINIUM_SITE_NAME=Scrinium

# ---- Reverse proxy ----
# Public hostname this instance is served as. Used by the nginx server_name
# and HSTS/redirect logic. Set to "localhost" for local-only HTTP testing.
SCRINIUM_DOMAIN=docs.example.com

# When the bundled nginx terminates TLS in front of Scrinium, keep both at 1
# so cookies are marked Secure and X-Forwarded-* headers are honoured.
SCRINIUM_TRUST_PROXY=1
SCRINIUM_HTTPS_ONLY=1

# ---- Ports published by the nginx container ----
# Rootless Podman cannot bind privileged host ports (<1024) unless the host
# allows it. The defaults are rootless-friendly; set these to 80/443 for
# production after enabling net.ipv4.ip_unprivileged_port_start=80 or when
# running behind a privileged host reverse proxy.
SCRINIUM_HTTP_PORT=8080
SCRINIUM_HTTPS_PORT=8443

# ---- TLS certificate (mounted into the nginx container) ----
# SCRINIUM_TLS_HOST_DIR is the directory on the HOST that contains your cert
# files. It is mounted read-only into the nginx container at /etc/ssl/scrinium.
# Drop your fullchain + key in there with the names below (or change the paths).
#
# Examples:
#   - Self-signed test cert generated by you: ./nginx/certs
#   - Wildcard cert copied from another host:  /etc/ssl/mycorp-wildcard
#   - certbot output:                          /etc/letsencrypt/live/docs.example.com
SCRINIUM_TLS_HOST_DIR=./nginx/certs
SCRINIUM_TLS_CERT=/etc/ssl/scrinium/fullchain.pem
SCRINIUM_TLS_KEY=/etc/ssl/scrinium/privkey.pem
